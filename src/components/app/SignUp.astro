---
import { Image } from "astro:assets";
import ImageFondo from "../../assets/logoCompleto.png";
---

<section class="min-h-screen w-full bg-CFE-900 px-4 py-6 sm:px-6 lg:px-8 flex items-center justify-center">
  <div class="w-full max-w-7xl lg:max-w-[1100px] xl:max-w-[1300px] min-h-[650px] lg:min-h-[750px] overflow-hidden rounded-xl bg-white shadow-2xl shadow-black grid grid-cols-1 lg:grid-cols-3">
    
    <figure class="flex items-center justify-center bg-CFE-800 p-8 sm:p-10 lg:col-span-2 lg:rounded-l-xl">
      <Image
        src={ImageFondo}
        alt="Logo EnergX"
        class="max-h-[240px] w-auto max-w-[80%] object-contain sm:max-h-[320px] lg:max-h-[80%]"
      />
    </figure>

    <form action="" method="post" class="flex items-center justify-center p-6 sm:p-8 lg:col-span-1 lg:p-0">
      <div class="flex w-full max-w-md flex-col items-center justify-center gap-4 sm:gap-5 lg:h-5/6 lg:w-4/5">
        <h2 class="text-4xl font-bold flex items-center justify-center sm:text-5xl lg:text-6xl">
          ENERG-<span class="text-CFE-700">X</span>
        </h2>

        <h3 class="text-xl font-semibold text-center sm:text-2xl">
          Crear cuenta
        </h3>

        <div class="w-full grid grid-cols-1 gap-4 lg:grid-cols-2">

          <input type="text" id="nombre" placeholder="Nombre" class="input" />
          <input type="text" id="apellidoP" placeholder="Apellido Paterno" class="input" />

          <input type="text" id="apellidoM" placeholder="Apellido Materno" class="input" />
          <input type="number" id="edad" placeholder="Edad" class="input" />

          <input type="text" id="pais" placeholder="País" class="input" />
          <input type="tel" id="telefono" placeholder="Teléfono" class="input" />

          <input type="email" id="correo" placeholder="Correo" class="input lg:col-span-2" />

          <input type="password" id="passw" placeholder="Contraseña" class="input" />
          <input type="password" id="confirmPassw" placeholder="Repetir Contraseña" class="input" />

        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-CFE-700 py-3 font-semibold text-white transition-all hover:bg-CFE-800"
        >
          Registrar
        </button>

        <p class="text-sm font-bold sm:text-base text-center">
          ¿Ya tienes una cuenta?
          <a href="/app/indexApp" class="text-CFE-700 hover:underline">LOGIN</a>
        </p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector("form");

  const nombre = document.getElementById("nombre") as HTMLInputElement | null;
  const apellidoP = document.getElementById("apellidoP") as HTMLInputElement | null;
  const apellidoM = document.getElementById("apellidoM") as HTMLInputElement | null;
  const edad = document.getElementById("edad") as HTMLInputElement | null;
  const pais = document.getElementById("pais") as HTMLInputElement | null;
  const email = document.getElementById("correo") as HTMLInputElement | null;
  const telefono = document.getElementById("telefono") as HTMLInputElement | null;
  const password = document.getElementById("passw") as HTMLInputElement | null;
  const confirmPassw = document.getElementById("confirmPassw") as HTMLInputElement | null;

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (
      !nombre ||
      !apellidoP ||
      !apellidoM ||
      !edad ||
      !pais ||
      !email ||
      !telefono ||
      !password ||
      !confirmPassw
    ) {
      alert("No se encontraron todos los campos del formulario.");
      return;
    }

    if (password.value !== confirmPassw.value) {
      alert("Las contraseñas no coinciden");
      return;
    }

    try {
      const registerResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/addUser`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          nombre: nombre.value,
          apellidoP: apellidoP.value,
          apellidoM: apellidoM.value,
          edad: edad.value,
          pais: pais.value,
          correo: email.value,
          telefono: telefono.value,
          passw: password.value,
        }),
      });

      const registerData = await registerResponse.json().catch(() => null);

      if (!registerResponse.ok) {
        alert(registerData?.message || "No se pudo registrar el usuario");
        return;
      }

      const loginResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/login`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          correo: email.value,
          passw: password.value,
        }),
      });

      const loginData = await loginResponse.json().catch(() => null);

      if (!loginResponse.ok) {
        alert(loginData?.message || "Usuario creado, pero no se pudo iniciar sesión");
        window.location.replace("/app/indexApp");
        return;
      }

      const meResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
        credentials: "include",
      });

      if (!meResponse.ok) {
        alert("Usuario creado, pero la sesión no se pudo confirmar");
        window.location.replace("/app/indexApp");
        return;
      }

      window.location.replace("/app/panelAdm");
    } catch (error) {
      console.error("Error en registro:", error);
      alert("Ocurrió un error al registrar el usuario");
    }
  });
</script>