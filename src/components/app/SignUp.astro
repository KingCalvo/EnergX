---
import { Image } from "astro:assets";
import ImageFondo from "../../assets/logoFoco.png";
---

<section class="w-full min-h-screen bg-ALI-900 px-4 py-10 sm:px-6 lg:px-8 flex justify-center items-start lg:items-center">
  <div class="w-full max-w-7xl lg:max-w-[1100px] xl:max-w-[1300px] lg:h-[600px] overflow-hidden rounded-xl bg-white shadow-2xl shadow-black grid grid-cols-1 lg:grid-cols-3">

    <figure class="flex items-center justify-center bg-ALI-800 p-8 sm:p-10 lg:col-span-2 lg:rounded-l-xl min-h-[240px] sm:min-h-[280px] lg:h-full">
      <Image
        src={ImageFondo}
        alt="Logo EnergX"
        class="max-h-[110px] sm:max-h-[140px] w-auto max-w-[75%] object-contain lg:max-h-[70%]"
      />
    </figure>

    <form id="signupForm" method="post" class="flex items-center justify-center p-6 sm:p-8 lg:col-span-1 lg:h-full">
      <div class="flex w-full max-w-md flex-col items-center justify-center gap-4 sm:gap-5">

        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-center">
          ENERG-<span class="text-ALI-800">X</span>
        </h2>

        <h3 class="text-xl sm:text-2xl font-semibold text-center text-gray-800">
          Crear cuenta
        </h3>

        <div class="w-full grid grid-cols-1 sm:grid-cols-2 gap-4">

          <input required type="text" id="nombre" placeholder="Nombre"
            class="input"
            pattern="^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ\s]+$"
            title="Solo letras"
          />

          <input required type="text" id="apellidoP" placeholder="Apellido Paterno"
            class="input"
            pattern="^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ\s]+$"
            title="Solo letras"
          />

          <input required type="text" id="apellidoM" placeholder="Apellido Materno"
            class="input"
            pattern="^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ\s]+$"
            title="Solo letras"
          />

          <input required type="text" id="edad" placeholder="Edad"
            class="input"
            inputmode="numeric"
            pattern="^(1[6-9]|[2-9][0-9]|100)$"
            maxlength="3"
            title="La edad debe ser entre 16 y 100 años"
          />

          <input required type="text" id="pais" placeholder="País"
            class="input"
            pattern="^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ\s]+$"
            title="Solo letras"
          />

          <input required type="text" id="telefono" placeholder="Teléfono"
            class="input"
            inputmode="numeric"
            pattern="^[0-9]{10}$"
            maxlength="10"
            title="10 dígitos"
          />

          <input required type="email" id="correo" placeholder="Correo"
            class="input sm:col-span-2"
          />

          <input required type="password" id="passw" placeholder="Contraseña"
            class="input"
            minlength="6"
          />

          <input required type="password" id="confirmPassw" placeholder="Repetir Contraseña"
            class="input"
            minlength="6"
          />

        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-ALI-800 py-3 font-semibold text-white transition-all hover:bg-ALI-900"
        >
          Registrar
        </button>

        <p class="text-sm sm:text-base font-bold text-center">
          ¿Ya tienes una cuenta?
          <a href="/app/indexApp" class="text-ALI-800 hover:underline">LOGIN</a>
        </p>

      </div>
    </form>
  </div>
</section>

<!-- MODAL -->
<div id="modalError" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50 px-4">
  <div class="bg-white rounded-xl shadow-2xl p-6 max-w-sm w-full text-center animate-fadeIn border border-gray-200">
    <h2 class="text-xl font-bold mb-3 text-red-600">
      No se pudo registrar
    </h2>

    <p class="text-slate-600 mb-5">
      Verifica los datos e inténtalo nuevamente.
    </p>

    <button
      id="closeModalError"
      class="bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700 transition-all"
    >
      Entendido
    </button>
  </div>
</div>

<style>
  .input {
    @apply w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-800 outline-none transition-all placeholder:text-gray-400 focus:border-ALI-800 focus:ring-2 focus:ring-ALI-800/20;
  }

  .input:focus:invalid {
    border-color: #dc2626;
    box-shadow: 0 0 0 2px rgba(220,38,38,0.2);
  }

  .input:not(:placeholder-shown):invalid {
    border-color: #dc2626;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .animate-fadeIn {
    animation: fadeIn 0.25s ease;
  }
</style>

<script>
  const form = document.getElementById("signupForm") as HTMLFormElement | null;

  const nombre = document.getElementById("nombre") as HTMLInputElement | null;
  const apellidoP = document.getElementById("apellidoP") as HTMLInputElement | null;
  const apellidoM = document.getElementById("apellidoM") as HTMLInputElement | null;
  const edad = document.getElementById("edad") as HTMLInputElement | null;
  const pais = document.getElementById("pais") as HTMLInputElement | null;
  const email = document.getElementById("correo") as HTMLInputElement | null;
  const telefono = document.getElementById("telefono") as HTMLInputElement | null;
  const password = document.getElementById("passw") as HTMLInputElement | null;
  const confirmPassw = document.getElementById("confirmPassw") as HTMLInputElement | null;

  const modalError = document.getElementById("modalError") as HTMLDivElement | null;
  const closeModalError = document.getElementById("closeModalError") as HTMLButtonElement | null;

  let autoCloseTimer: ReturnType<typeof setTimeout> | null = null;

  function showModalError() {
    if (!modalError) return;

    modalError.classList.remove("hidden");

    if (autoCloseTimer) clearTimeout(autoCloseTimer);

    autoCloseTimer = setTimeout(() => {
      modalError.classList.add("hidden");
    }, 3000);
  }

  function hideModalError() {
    if (!modalError) return;

    modalError.classList.add("hidden");

    if (autoCloseTimer) {
      clearTimeout(autoCloseTimer);
      autoCloseTimer = null;
    }
  }

  function validatePasswords() {
    if (!password || !confirmPassw) return;

    if (confirmPassw.value && password.value !== confirmPassw.value) {
      confirmPassw.setCustomValidity("Las contraseñas no coinciden");
    } else {
      confirmPassw.setCustomValidity("");
    }
  }

  password?.addEventListener("input", validatePasswords);
  confirmPassw?.addEventListener("input", validatePasswords);

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (
      !form ||
      !nombre ||
      !apellidoP ||
      !apellidoM ||
      !edad ||
      !pais ||
      !email ||
      !telefono ||
      !password ||
      !confirmPassw
    ) {
      showModalError();
      return;
    }

    validatePasswords();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    try {
      const registerResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/addUser`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          nombre: nombre.value,
          apellidoP: apellidoP.value,
          apellidoM: apellidoM.value,
          edad: edad.value,
          pais: pais.value,
          correo: email.value,
          telefono: telefono.value,
          passw: password.value,
        }),
      });

      if (!registerResponse.ok) {
        showModalError();
        return;
      }

      const loginResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/login`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          correo: email.value,
          passw: password.value,
        }),
      });

      if (!loginResponse.ok) {
        showModalError();
        window.location.replace("/app/indexApp");
        return;
      }

      const meResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
        credentials: "include",
      });

      if (!meResponse.ok) {
        showModalError();
        window.location.replace("/app/indexApp");
        return;
      }

      window.location.replace("/app/panelAdm");

    } catch (error) {
      console.error("Error en registro:", error);
      showModalError();
    }
  });

  closeModalError?.addEventListener("click", hideModalError);

  modalError?.addEventListener("click", (e) => {
    if (e.target === modalError) {
      hideModalError();
    }
  });
</script>