---
import { Image } from "astro:assets";
import ImageFondo from "../../assets/logoFoco.png";
---

<section class="w-full min-h-screen bg-ALI-900 px-4 py-10 sm:px-6 lg:px-8 flex justify-center items-start lg:items-center">
  <div class="w-full max-w-7xl lg:max-w-[1100px] xl:max-w-[1300px] lg:h-[600px] overflow-hidden rounded-xl bg-white shadow-2xl shadow-black grid grid-cols-1 lg:grid-cols-3">
    
    <figure class="flex items-center justify-center bg-ALI-800 p-8 sm:p-10 lg:col-span-2 lg:rounded-l-xl min-h-[240px] sm:min-h-[280px] lg:h-full">
      <Image
        src={ImageFondo}
        alt="Logo EnergX"
        class="max-h-[110px] sm:max-h-[140px] w-auto max-w-[75%] object-contain lg:max-h-[70%]"
      />
    </figure>

    <form id="loginForm" method="post" class="flex items-center justify-center p-6 sm:p-8 lg:col-span-1 lg:h-full">
      <div class="flex w-full max-w-md flex-col items-center justify-center gap-5 sm:gap-6">
        <h2 class="text-4xl sm:text-5xl lg:text-7xl font-bold flex items-center justify-center text-center leading-none">
          ENERG-<span class="text-ALI-800">X</span>
        </h2>

        <input
          required
          type="email"
          id="emailLogin"
          placeholder="email"
          class="w-full border-b-2 bg-transparent px-2 py-3 text-base outline-none transition-all focus:border-CFE-700 sm:text-lg"
        />

        <input
          required
          type="password"
          id="password"
          placeholder="Password"
          class="w-full border-b-2 bg-transparent px-2 py-3 text-base outline-none transition-all focus:border-CFE-700 sm:text-lg"
        />

        <p class="w-full text-end">
          <a href="#" class="font-bold text-CFE-900 transition-all hover:text-ALI-800">
            Forget password
          </a>
        </p>

        <button
          type="submit"
          id="login"
          class="w-full rounded-lg bg-ALI-800 py-3 font-semibold text-white transition-all hover:bg-ALI-900"
        >
          Login
        </button>

        <div class="flex justify-center text-center">
          <p class="text-sm font-bold sm:text-base">
            ¿No tienes una cuenta?
            <a href="/app/registroLogin" class="text-ALI-800 hover:underline">Regístrate aquí</a>
          </p>
        </div>

        <p class="flex items-center justify-center gap-2 font-bold text-sm sm:text-base">
          <a href="/" class="text-ALI-800 hover:underline">Conócenos</a>
        </p>
      </div>
    </form>
  </div>
</section>

<!-- MODAL DE ERROR -->
<div id="modalError" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50 px-4">
  <div class="bg-white rounded-xl shadow-2xl p-6 max-w-sm w-full text-center animate-fadeIn border border-gray-200">
    <h2 class="text-xl font-bold mb-3 text-red-600">
      Correo o contraseña incorrectos
    </h2>

    <p class="text-slate-600 mb-5">
      Verifica tus credenciales e inténtalo nuevamente.
    </p>

    <button
      id="closeModalError"
      class="bg-red-600 text-white px-6 py-2 rounded-lg hover:bg-red-700 transition-all"
    >
      Entendido
    </button>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .animate-fadeIn {
    animation: fadeIn 0.25s ease;
  }
</style>

<script>
  const form = document.getElementById("loginForm") as HTMLFormElement | null;
  const email = document.getElementById("emailLogin") as HTMLInputElement | null;
  const password = document.getElementById("password") as HTMLInputElement | null;

  const modalError = document.getElementById("modalError") as HTMLDivElement | null;
  const closeModalError = document.getElementById("closeModalError") as HTMLButtonElement | null;

  let autoCloseTimer: ReturnType<typeof setTimeout> | null = null;

  function showModalError() {
    if (!modalError) return;

    modalError.classList.remove("hidden");

    if (autoCloseTimer) {
      clearTimeout(autoCloseTimer);
    }

    autoCloseTimer = setTimeout(() => {
      modalError.classList.add("hidden");
    }, 3000);
  }

  function hideModalError() {
    if (!modalError) return;

    modalError.classList.add("hidden");

    if (autoCloseTimer) {
      clearTimeout(autoCloseTimer);
      autoCloseTimer = null;
    }
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!email || !password) return;

    try {
      const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/login`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          correo: email.value,
          passw: password.value,
        }),
      });

      await response.json().catch(() => null);

      if (!response.ok) {
        showModalError();
        return;
      }

      const meResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
        credentials: "include",
      });

      if (!meResponse.ok) {
        showModalError();
        return;
      }

      window.location.replace("/app/panelAdm");
    } catch (error) {
      console.error("Error en login:", error);
      showModalError();
    }
  });

  closeModalError?.addEventListener("click", hideModalError);

  modalError?.addEventListener("click", (e) => {
    if (e.target === modalError) {
      hideModalError();
    }
  });
</script>