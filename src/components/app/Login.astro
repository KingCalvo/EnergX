---
import { Image } from "astro:assets";
import ImageFondo from "@assets/logoCompleto.png";
---

<section class="w-5/6 h-5/6 bg-white grid grid-cols-3 grid-rows-1 rounded-xl shadow-2xl shadow-black">
  <figure class="col-span-2 flex justify-center items-center bg-CFE-800 rounded-l-xl">
    <Image
      src={ImageFondo}
      alt="Logo EnergX"
      class="max-w-[80%] max-h-[80%] object-contain"
    />
  </figure>

  <form action="" method="post" class="rounded-xl col-span-1 flex items-center justify-center">
    <div class="w-4/6 h-4/5 flex flex-col justify-center items-center gap-8">
      <h2 class="text-7xl font-bold flex justify-center items-center">
        ENERG-<span class="text-CFE-700">X</span>
      </h2>

      <input
        required
        type="email"
        id="emailLogin"
        placeholder="email"
        class="w-full bg-transparent border-b-2 focus:outline-none"
      />

      <input
        required
        type="password"
        id="password"
        placeholder="Password"
        class="w-full bg-transparent border-b-2 focus:outline-none"
      />

      <p class="w-full text-end">
        <a href="#" class="text-CFE-900 font-bold hover:text-CFE-800 transition-all">
          Forget password
        </a>
      </p>

      <button
        type="submit"
        id="login"
        class="w-full rounded-lg bg-CFE-700 py-3 font-semibold text-white hover:bg-CFE-800 transition-all"
      >
        Login
      </button>

      <div class="flex justify-center">
        <p class="font-bold text-sm">
          ¿No tienes una cuenta?
          <a href="/app/registroLogin" class="text-CFE-700 hover:underline">Regístrate aquí</a>
        </p>
      </div>

      <p class="font-bold flex justify-center items-center gap-2">
        <a href="/" class="text-CFE-700 hover:underline">Conócenos</a>
      </p>
    </div>
  </form>
</section>

<script>
  const form = document.querySelector("form");

  const email = document.getElementById("emailLogin") as HTMLInputElement | null;
  const password = document.getElementById("password") as HTMLInputElement | null;

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!email || !password) {
      alert("No se encontraron los campos del formulario.");
      return;
    }

    const apiUrl = `${import.meta.env.PUBLIC_API_URL}/api/login`;

    try {
      const response = await fetch(apiUrl, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          correo: email.value,
          passw: password.value,
        }),
      });

      const result = await response.json();

      if (!response.ok) {
        alert(result?.message || "El usuario o contraseña son incorrectos");
        return;
      }

      if (result?.user?.idUsuario) {
        localStorage.setItem("userId", String(result.user.idUsuario));
      }

      window.location.href = "/app/panelAdm";
    } catch (error) {
      console.error("Error en login:", error);
      alert("Ocurrió un error al iniciar sesión");
    }
  });
</script>