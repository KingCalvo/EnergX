---
import { Image } from "astro:assets";
import ImageFondo from "../../assets/logoCompleto.png";
---

<section class="min-h-screen w-full bg-ALI-900 px-4 py-6 sm:px-6 lg:px-8 flex items-center justify-center">
  <div class="w-full max-w-7xl lg:max-w-[1100px] xl:max-w-[1300px] min-h-[650px] lg:min-h-[750px] overflow-hidden rounded-xl bg-white shadow-2xl shadow-black grid grid-cols-1 lg:grid-cols-3">
    
    <figure class="flex items-center justify-center bg-ALI-800 p-8 sm:p-10 lg:col-span-2 lg:rounded-l-xl">
      <Image
        src={ImageFondo}
        alt="Logo EnergX"
        class="max-h-[240px] w-auto max-w-[80%] object-contain sm:max-h-[320px] lg:max-h-[80%]"
      />
    </figure>

    <form action="" method="post" class="flex items-center justify-center p-6 sm:p-8 lg:col-span-1 lg:p-0">
      <div class="flex w-full max-w-md flex-col items-center justify-center gap-6 sm:gap-8 lg:h-4/5 lg:w-4/5">
        <h2 class="text-4xl font-bold flex items-center justify-center sm:text-5xl lg:text-7xl">
          ENERG-<span class="text-ALI-800">X</span>
        </h2>

        <input
          required
          type="email"
          id="emailLogin"
          placeholder="email"
          class="w-full border-b-2 bg-transparent px-2 py-3 text-base outline-none transition-all focus:border-CFE-700 sm:text-lg"
        />

        <input
          required
          type="password"
          id="password"
          placeholder="Password"
          class="w-full border-b-2 bg-transparent px-2 py-3 text-base outline-none transition-all focus:border-CFE-700 sm:text-lg"
        />

        <p class="w-full text-end">
          <a href="#" class="font-bold text-CFE-900 transition-all hover:text-ALI-800">
            Forget password
          </a>
        </p>

        <button
          type="submit"
          id="login"
          class="w-full rounded-lg bg-ALI-800 py-3 font-semibold text-white transition-all hover:bg-ALI-900"
        >
          Login
        </button>

        <div class="flex justify-center text-center">
          <p class="text-sm font-bold sm:text-base">
            ¿No tienes una cuenta?
            <a href="/app/registroLogin" class="text-ALI-800 hover:underline">Regístrate aquí</a>
          </p>
        </div>

        <p class="flex items-center justify-center gap-2 font-bold text-sm sm:text-base">
          <a href="/" class="text-ALI-800 hover:underline">Conócenos</a>
        </p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector("form");

  const email = document.getElementById("emailLogin") as HTMLInputElement | null;
  const password = document.getElementById("password") as HTMLInputElement | null;

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!email || !password) return;

    try {
      const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/login`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          correo: email.value,
          passw: password.value,
        }),
      });

      const result = await response.json().catch(() => null);

      if (!response.ok) {
        alert(result?.message || "Error al iniciar sesión");
        return;
      }

      const meResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
        credentials: "include",
      });

      if (!meResponse.ok) {
        alert("La sesión no se pudo confirmar");
        return;
      }

      window.location.replace("/app/panelAdm");
    } catch (error) {
      console.error("Error en login:", error);
      alert("No se pudo iniciar sesión");
    }
  });
</script>