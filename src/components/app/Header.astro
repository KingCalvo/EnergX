---
import { FaPowerOff } from 'react-icons/fa'
import { FaArrowLeft } from "react-icons/fa";
---

<header class="bg-ALI-800 flex items-center justify-between px-4 py-5">

  <!-- BOTÓN BACK -->
  <a href="#" id="back-button" class="flex items-center">
    <FaArrowLeft className="text-2xl sm:text-4xl text-white" />
  </a>

  <!-- LOGO TEXTO -->
  <div class="flex justify-center items-center">
    <h1 class="text-2xl sm:text-4xl font-bold text-white">
      Energ-<span class="text-ALI-600">X</span>
    </h1>
  </div>

  <!-- LOGOUT -->
  <div class="flex items-center">
    <button type="button" id="logout-button" aria-label="Cerrar sesión">
      <FaPowerOff className="text-2xl sm:text-4xl text-white" />
    </button>
  </div>

</header>

<script>
  const backButton = document.getElementById("back-button");
  const logoutButton = document.getElementById("logout-button");

  backButton?.addEventListener("click", (event) => {
    event.preventDefault();
    window.history.back();
  });

  logoutButton?.addEventListener("click", async () => {
    try {
      await fetch(`${import.meta.env.PUBLIC_API_URL}/api/logout`, {
        method: "POST",
        credentials: "include",
      });

      window.location.href = "/app/indexApp";
    } catch (error) {
      console.error("Error al cerrar sesión:", error);
      alert("No se pudo cerrar sesión");
    }
  });
</script>