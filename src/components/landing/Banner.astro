---
---

<header id="banner" class="w-full flex justify-center transition-all duration-300">

  <nav id="navContainer"
    class="flex items-center justify-between w-full px-4 py-2 mt-4 rounded-full border border-slate-200 bg-CFE-800 shadow-md backdrop-blur-md transition-all duration-300
           max-w-[95%] md:max-w-[95%] lg:max-w-fit lg:px-3 lg:gap-2">

    <!-- Mobile -->
    <div class="flex w-full items-center justify-between lg:hidden">

      <div class="text-white font-bold text-base">
        Energ-X
      </div>

      <button id="menuBtn" class="text-white text-2xl">
        ☰
      </button>

    </div>

    <!-- Desktop -->
    <div class="hidden lg:flex gap-2">
      <a href="/" class="nav-item">Inicio</a>
      <a href="/landing/oferta" class="nav-item">Servicios</a>
      <a href="/app/indexApp" class="nav-item">WebApp</a>
      <a href="/landing/products" class="nav-item">Dispositivos</a>
      <a href="/landing/about" class="nav-item">Sobre Nosotros</a>
    </div>

  </nav>

  <!-- MOBILE MENU -->
  <div id="mobileMenu"
    class="hidden fixed left-0 w-full px-4 z-50 lg:hidden">

    <div class="bg-CFE-800 rounded-2xl shadow-lg flex flex-col items-center py-4 gap-2 border border-white/10 backdrop-blur-md">

      <a href="/" class="nav-item w-full text-center">Inicio</a>
      <a href="/landing/oferta" class="nav-item w-full text-center">Servicios</a>
      <a href="/app/indexApp" class="nav-item w-full text-center">WebApp</a>
      <a href="/landing/products" class="nav-item w-full text-center">Dispositivos</a>
      <a href="/landing/about" class="nav-item w-full text-center">Sobre Nosotros</a>

    </div>
  </div>

</header>

<script>
const banner = document.getElementById("banner");
const nav = document.getElementById("navContainer");
const menuBtn = document.getElementById("menuBtn");
const mobileMenu = document.getElementById("mobileMenu");

// posicionar menú debajo del navbar
function updateMenuPosition() {
  if (!nav || !mobileMenu) return;

  const rect = nav.getBoundingClientRect();
  mobileMenu.style.top = rect.bottom + 10 + "px";
}

// sticky navbar
if (banner) {
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      banner.classList.add("fixed", "top-6", "left-0", "right-0", "z-50");
    } else {
      banner.classList.remove("fixed", "top-6", "left-0", "right-0", "z-50");
    }

    updateMenuPosition(); 
  });
}

// abrir/cerrar menú
if (menuBtn && mobileMenu) {
  menuBtn.addEventListener("click", () => {
    mobileMenu.classList.toggle("hidden");
    updateMenuPosition(); 
  });
}

// cerrar al hacer click en links
if (mobileMenu) {
  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
    });
  });
}

// ajustar al cargar y resize
window.addEventListener("load", updateMenuPosition);
window.addEventListener("resize", updateMenuPosition);
</script>

<style>
  .nav-item {
    @apply inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-medium text-white transition-all duration-300;
  }

  .nav-item:hover {
    @apply bg-slate-100 text-slate-900 scale-105;
  }

  .nav-item.active {
    @apply bg-slate-950 text-white shadow-md;
  }
</style>