---
import Layout from '../../layouts/Layout.astro';
import BaseL from '../../layouts/BaseLayout.astro';
import Happy from "../../assets/mascota_happy.png";
import Sad from "../../assets/mascota_sad.png";

import frases from "../../data/consejos.json";

import Mascota from '../../components/app/animations/Mascota';
import Barras from '../../components/app/animations/Barras';

const promedioData = 242.25;
const promedioDataTwo = 588.00;

const numeroAleatorio = Math.floor(Math.random() * 15);
const positive = frases[0].phrases[numeroAleatorio];
const negative = frases[1].phrases[numeroAleatorio];

const resultado = ((promedioDataTwo - promedioData) / promedioData) * 100;
---

<script>
  fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
    credentials: "include",
  })
    .then((res) => {
      if (!res.ok) window.location.href = "/app/indexApp";
    })
    .catch(() => {
      window.location.href = "/app/indexApp";
    });
</script>

<Layout title="Panel">
  <main class="min-h-screen w-full overflow-x-hidden">
    <BaseL>

      <div class="w-full p-3 grid gap-4 lg:grid-cols-2">

        <!-- IZQUIERDA -->
        <div class="flex flex-col gap-4 lg:justify-center">

          <!-- TEXTO -->
          <div class="bg-slate-300 rounded-xl p-4 shadow-md">
            <p class="text-sm sm:text-base text-justify">
              Bienvenido al panel de administración de Energ-X. Desde aquí puedes registrar nuevos dispositivos, gestionar las áreas monitoreadas y analizar el consumo energético en tiempo real.
            </p>
          </div>

          <!-- BOTÓN -->
          <a href="/app/formDispositivo"
            class="flex items-center justify-center bg-teal-700 rounded-xl text-white font-semibold h-14 sm:h-16 hover:bg-teal-900 transition-all">
            Registrar nuevo dispositivo
          </a>

          <!-- ÁREAS -->
          <div class="bg-slate-300 rounded-xl p-4 shadow-md flex flex-col items-center">

            <h2 class="text-2xl font-semibold mb-2">Áreas</h2>

            <ol id="areasList" class="w-full mt-2 flex flex-col gap-2 pl-6 list-decimal">
              <li class="text-gray-500">Cargando áreas...</li>
            </ol>

            <a href="/app/panelEdificios"
              class="mt-6 w-80 text-center bg-teal-700 text-white py-2 rounded-lg font-semibold hover:bg-teal-900 transition-all">
              Ver todas
            </a>

          </div>

          <!-- GRÁFICA -->
          <div class="bg-slate-300 rounded-xl p-4 shadow-md">
            <h2 class="text-center text-2xl font-semibold mb-3">Seguimiento semanal por área</h2>

            <div class="w-full h-[260px] sm:h-[300px] lg:h-[300px] rounded-xl p-2">
              <Barras client:load />
            </div>
          </div>

        </div>

        <!-- DERECHA -->
        <div class="bg-slate-300 rounded-xl p-4 shadow-md flex flex-col 
                    lg:min-h-[85vh]">

          <div class="mt-2 lg:mt-6"></div>

          <h3 class="text-center text-xl sm:text-2xl font-bold mb-4 lg:mb-6">
            Por un consumo de energía más amigable para todos.
          </h3>

          <ul class="flex flex-col gap-2 sm:gap-3 text-sm sm:text-base mb-4 text-center">
            <li>Semana pasada: <span class="font-bold text-teal-700">{promedioData} Kwh</span></li>
            <li>Semana actual: <span class="font-bold text-teal-700">{promedioDataTwo} Kwh</span></li>
          </ul>

          <p class="text-center text-sm sm:text-base mb-4 text-slate-700 px-2 sm:px-4">
            Descubre recomendaciones inteligentes de ahorro energético con LowerG.
          </p>

          <!-- SOLO CRECE EN PC -->
         <div class="hidden lg:block flex-grow-[0.5]"></div>

          <!-- MASCOTA -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 mt-2 lg:mt-20 mb-2 lg:mb-6">

            <Mascota client:load>
              <div class="flex items-center justify-center 
                          w-32 h-32 sm:w-40 sm:h-40 lg:w-52 lg:h-52 
                          bg-slate-200 rounded-full p-2 text-center shadow-md">
                
                <p class="text-[10px] sm:text-sm leading-tight break-words px-1">
                  {promedioData > promedioDataTwo
                    ? positive + " Ahorraste el " + (Math.round(resultado) * -1) + "%"
                    : negative + " Gastaste un " + Math.round(resultado) + "% más."
                  }
                </p>

              </div>
            </Mascota>

            <Mascota client:load>
              <img
                src={promedioData > promedioDataTwo ? Happy.src : Sad.src}
                class="w-32 h-32 sm:w-40 sm:h-40 lg:w-52 lg:h-52 object-contain"
              />
            </Mascota>

          </div>

        </div>

      </div>

    </BaseL>
  </main>
</Layout>
<script>
  const areasList = document.getElementById("areasList");

  async function loadAreas() {
    if (!areasList) return;

    try {
      const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/areas`, {
        credentials: "include",
      });

      const data = await res.json();

      if (!res.ok || !data.success) throw new Error();

      const areas = data.areas.slice(0, 3);

      if (!areas.length) {
        areasList.innerHTML = `<li class="text-gray-500">No hay áreas registradas.</li>`;
        return;
      }

      let html = "";

      for (let i = 0; i < areas.length; i++) {
        const area = areas[i];

        html += `
          <li>
            <a href="/app/panelAreas?id=${area.id_dispositivo}" 
               class="text-teal-700 font-bold hover:text-teal-900">
              ${area.nombre_area}
            </a>
          </li>
        `;
      }

      areasList.innerHTML = html;

    } catch {
      areasList.innerHTML = `
        <li class="text-red-500 font-semibold">
          No se pudieron cargar las áreas.
        </li>
      `;
    }
  }

  loadAreas();
</script>