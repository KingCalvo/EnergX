---
import Layout from '../../layouts/Layout.astro';
import BaseL from '../../layouts/BaseLayout.astro';
import MedidorE from '../../components/app/animations/MedidorEstatico';
import LineasG from '../../components/app/animations/Lineas';
import { TbRefresh } from "react-icons/tb";

// valores base (no dependen de BD)
const consumo_kWh = 1.93;
const dia = 70;
const semanaKwh = dia * 7;
const costo_kWh = 1.2;
const factor_emision_CO2e = 0.464;
---

<script>
  fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
    credentials: "include",
  })
    .then((res) => {
      if (!res.ok) window.location.href = "/app/indexApp";
    })
    .catch(() => {
      window.location.href = "/app/indexApp";
    });
</script>

<Layout title="Panel - Areas">
  <main class="min-h-screen w-full overflow-x-hidden">
    <BaseL>

      <section class="w-full px-4 py-6 flex justify-center items-start lg:items-center min-h-[85vh]">
        <div class="w-full max-w-6xl mx-auto bg-white border border-gray-300 rounded-lg shadow-lg p-4 sm:p-6">

          <!-- HEADER DINÁMICO -->
          <div class="w-full text-center mb-6">
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-800 tracking-tight">
              Monitoreo del área 
              <span id="nombreArea" class="text-teal-700">Cargando...</span>
            </h1>
          </div>
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-4">
            <div class="text-lg font-semibold text-gray-800">
              <p id="edificio"></p>
              <p id="metros"></p>
            </div>

            <select class="p-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-CFE-800">
              <option disabled selected>Alertas</option>
              <option>Correo</option>
              <option>WhatsApp</option>
            </select>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">

            <!-- GRÁFICA -->
            <div class="bg-gray-100 border border-gray-300 rounded-lg p-3 flex flex-col items-center">
              <p class="font-bold mb-2 text-center">Evolución de la potencia</p>
              <div class="w-full max-w-full overflow-hidden">
                <LineasG client:load />
              </div>
            </div>

            <!-- MEDIDOR -->
            <div class="bg-gray-100 border border-gray-300 rounded-lg p-3 flex flex-col items-center">
              
              <div class="flex flex-col sm:flex-row items-center justify-between w-full gap-3 mb-3">
                <p class="font-bold text-center sm:text-left">Consumo en kWh</p>

                <div class="flex items-center gap-3">
                  <TbRefresh className="text-gray-700 text-2xl sm:text-3xl" />

                  <select class="p-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-CFE-800">
                    <option disabled selected>Tiempo</option>
                    <option>5 minutos</option>
                    <option>10 minutos</option>
                  </select>
                </div>
              </div>

              <div class="w-full flex justify-center overflow-hidden">
                <MedidorE client:load />
              </div>

            </div>

            <!-- FACTURACIÓN -->
            <div class="bg-gray-100 border border-gray-300 rounded-lg p-3 flex flex-col sm:flex-row items-center justify-center gap-2 text-center">
              <p class="font-bold">Facturación por semana:</p>
              <span id="facturacion" class="font-semibold"></span>
            </div>

            <!-- ÍNDICES -->
            <div class="bg-gray-100 border border-gray-300 rounded-lg p-4">
              <h2 class="font-bold text-center mb-3">Índices de consumo</h2>

              <div class="flex flex-col sm:flex-row justify-between gap-3 text-center sm:text-left">
                <p>
                  Consumo por m²:
                  <span id="consumoM2" class="font-semibold"></span>
                </p>

                <p>
                  Emisión de CO2e/m²:
                  <span id="co2M2" class="font-semibold"></span>
                </p>
              </div>
            </div>

          </div>

        </div>
      </section>

    </BaseL>
  </main>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const id = params.get("id");

  const nombreEl = document.getElementById("nombreArea");
  const edificioEl = document.getElementById("edificio");
  const metrosEl = document.getElementById("metros");

  const facturacionEl = document.getElementById("facturacion");
  const consumoM2El = document.getElementById("consumoM2");
  const co2M2El = document.getElementById("co2M2");

  const consumo_kWh = 1.93;
  const dia = 70;
  const semanaKwh = dia * 7;
  const costo_kWh = 1.2;
  const factor_emision_CO2e = 0.464;

  async function loadDispositivo() {
    if (!id) {
      if (nombreEl) nombreEl.textContent = "Área no disponible";
      return;
    }

    try {
      const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/dispositivo/${id}`, {
        credentials: "include",
      });

      const data = await res.json();

      if (!res.ok || !data.success) throw new Error();

      const d = data.dispositivo;

      const area_m2 = d.metros;

      const facturacion = semanaKwh * costo_kWh;
      const consumoM2 = semanaKwh / area_m2;
      const co2M2 = (semanaKwh * factor_emision_CO2e) / area_m2;

      if (nombreEl) nombreEl.textContent = d.nombre_area;
      if (edificioEl) edificioEl.textContent = d.edificio;
      if (metrosEl) metrosEl.textContent = `Área: ${area_m2} m²`;

      if (facturacionEl) facturacionEl.textContent = `${facturacion.toFixed(2)} MXN`;
      if (consumoM2El) consumoM2El.textContent = `${consumoM2.toFixed(2)} kWh/m²`;
      if (co2M2El) co2M2El.textContent = `${co2M2.toFixed(2)} CO2e/m²`;

    } catch {
      if (nombreEl) nombreEl.textContent = "Error al cargar datos";
      if (edificioEl) edificioEl.textContent = "";
      if (metrosEl) metrosEl.textContent = "";
    }
  }

  loadDispositivo();
</script>