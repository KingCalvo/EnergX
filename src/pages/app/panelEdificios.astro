---
import Layout from '../../layouts/Layout.astro';
import BaseL from '../../layouts/BaseLayout.astro';
import { Image } from "astro:assets";
import AreaImg from "../../assets/edificios.png";
import { FaBuilding } from "react-icons/fa6";
---

<script>
  fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
    credentials: "include",
  })
    .then((res) => {
      if (!res.ok) {
        window.location.href = "/app/indexApp";
      }
    })
    .catch(() => {
      window.location.href = "/app/indexApp";
    });
</script>

<Layout title="Panel de Edificios">
  <main class="min-h-screen w-full overflow-x-hidden">
    <BaseL>
      <section class="w-full px-4 py-4 sm:px-6 lg:px-8">
        
        <!-- CONTENEDOR -->
        <div 
          id="contenedorEdificios"
          data-img={AreaImg.src}
          class="mx-auto grid w-full max-w-7xl grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
        >
          <p class="text-center col-span-full">Cargando...</p>
        </div>

      </section>
    </BaseL>
  </main>
</Layout>

<script>
  const contenedor = document.getElementById("contenedorEdificios") as HTMLDivElement | null;

  async function loadEdificios() {
    if (!contenedor) return;

    const imgSrc = contenedor.dataset.img;

    try {
      const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/edificios`, {
        credentials: "include",
      });

      const data: {
        success: boolean;
        edificios: {
          id_dispositivo: number;
          edificio: string;
          nombre_area: string;
          metros: number;
        }[];
      } = await res.json();

      if (!res.ok || !data.success) {
        throw new Error();
      }

      if (!data.edificios.length) {
        contenedor.innerHTML = `
          <p class="text-center text-gray-500 col-span-full">
            No hay datos registrados.
          </p>
        `;
        return;
      }

      contenedor.innerHTML = data.edificios
        .map(
          (item) => `
        <a href="/app/panelAreas?id=${item.id_dispositivo}" class="block">
          <article class="flex h-full min-h-56 flex-col rounded-xl bg-slate-300 p-4 shadow-md transition-all hover:scale-[1.02] hover:shadow-lg">
            <div class="mb-3 flex items-start justify-between gap-3">
              <div>
                <h2 class="text-lg font-semibold sm:text-xl">
                  ${item.edificio}
                </h2>

                <p class="text-sm font-medium text-slate-700 text-center sm:text-left">
                  ${item.nombre_area}
                </p>
              </div>

              <span class="text-3xl text-slate-700 shrink-0">🏢</span>
            </div>

            <div class="mt-auto flex flex-1 items-center justify-center">
              <img
                src="${imgSrc}"
                class="h-24 w-24 object-contain sm:h-28 sm:w-28"
                alt="Edificios"
              />
            </div>
          </article>
        </a>
      `,
        )
        .join("");
    } catch {
      contenedor.innerHTML = `
        <div class="col-span-full flex items-center justify-center min-h-[300px]">
          <p class="text-red-500 font-bold text-center">
            No se pudieron cargar los edificios.
          </p>
        </div>
      `;
    }
  }

  loadEdificios();
</script>