---
import Layout from '../../layouts/Layout.astro';
import BaseL from '../../layouts/BaseLayout.astro';
import Barras from '../../components/app/animations/Barras';
---

<script>
  fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
    credentials: "include",
  })
    .then((res) => {
      if (!res.ok) {
        window.location.href = "/app/indexApp";
      }
    })
    .catch(() => {
      window.location.href = "/app/indexApp";
    });
</script>

<Layout title="Consumo Histórico">
  <main class="min-h-screen w-full overflow-x-hidden">
    <BaseL>
      <section class="mx-auto w-full max-w-5xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-gray-300 bg-white p-4 shadow-lg sm:p-6 lg:p-8">
          <div class="mx-auto w-full max-w-[900px]">
            <div class="h-[280px] sm:h-[340px] lg:h-[420px]">
              <Barras client:load />
            </div>
          </div>
        </div>
      </section>
    </BaseL>
  </main>
</Layout>