---
import Layout from '../../layouts/Layout.astro';
import BaseL from '../../layouts/BaseLayout.astro';
---

<script>
  fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
    credentials: "include",
  })
    .then((res) => {
      if (!res.ok) window.location.href = "/app/indexApp";
    })
    .catch(() => {
      window.location.href = "/app/indexApp";
    });
</script>

<Layout title="Dispositivo">
  <main class="min-h-screen w-full overflow-x-hidden">
    <BaseL>

      <section class="w-full min-h-[calc(100vh-80px)] flex items-center justify-center px-4 py-6">
        <div class="w-full max-w-3xl">

          <!-- TEXTO SUPERIOR -->
          <div class="bg-white rounded-xl shadow-md p-6 mb-6 border border-gray-200">
            <h1 class="text-2xl sm:text-3xl font-bold mb-3 text-center">
              Registro de dispositivo Energ-X
            </h1>

            <p class="text-sm sm:text-base text-justify text-slate-600 text-center leading-6">
              Ingresa la información correspondiente a tu dispositivo Energ-X para su configuración dentro del sistema.
              Esto permitirá monitorear el consumo energético de forma precisa, optimizar el rendimiento de tus áreas
              y mejorar la eficiencia en el uso de recursos eléctricos.
            </p>
          </div>

          <!-- FORM -->
          <form id="dispositivoForm"
            class="bg-white rounded-xl shadow-lg border border-gray-200 p-6 sm:p-8 flex flex-col gap-5">

            <input 
              required 
              type="text" 
              placeholder="ID del dispositivo" 
              class="input"
            />

            <input 
              required 
              type="text" 
              placeholder="Nombre del área" 
              class="input"
            />

            <input 
              required 
              type="number" 
              placeholder="Metros cuadrados del área" 
              class="input"
            />

            <select class="input">
              <option disabled selected>Tipo de consumo</option>
              <option>Voltaje monofásico: 127 V</option>
              <option>Voltaje trifásico: 220 V</option>
            </select>

            <input 
              required 
              type="text" 
              placeholder="Edificio" 
              class="input"
            />

            <button
              type="submit"
              class="w-full bg-CFE-800 text-white font-semibold py-3 rounded-lg transition-all hover:bg-CFE-900"
            >
              Agregar dispositivo
            </button>

          </form>
        </div>
      </section>

      <!-- MODAL -->
      <div id="modal" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50">
        <div class="bg-white rounded-xl shadow-2xl p-6 max-w-sm w-full text-center animate-fadeIn">

          <h2 class="text-xl font-bold mb-3 text-CFE-800">
            Acción no disponible
          </h2>

          <p class="text-slate-600 mb-5">
            No puedes agregar un dispositivo porque no has adquirido ninguno.
          </p>

          <button id="closeModal"
            class="bg-CFE-800 text-white px-6 py-2 rounded-lg hover:bg-CFE-900 transition-all">
            Entendido
          </button>

        </div>
      </div>

    </BaseL>
  </main>
</Layout>

<style>
  .input {
    @apply w-full p-3 border border-gray-300 rounded-lg outline-none transition-all focus:ring-2 focus:ring-CFE-700;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .animate-fadeIn {
    animation: fadeIn 0.25s ease;
  }
</style>

<script>
  const form = document.getElementById("dispositivoForm");
  const modal = document.getElementById("modal");
  const closeModal = document.getElementById("closeModal");

  if (form && modal && closeModal) {

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      modal.classList.remove("hidden");
    });

    closeModal.addEventListener("click", () => {
      modal.classList.add("hidden");
    });

    modal.addEventListener("click", (e) => {
      if (e.target === modal) {
        modal.classList.add("hidden");
      }
    });

  }
</script>